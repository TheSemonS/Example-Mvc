@model GameDisplayCreateResponse
@{
    ViewData["Title"] = "Добавить игру";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-4">
                <div class="card-body">
                    <h2 class="fw-bold text-primary mb-1">Добавить игру</h2>
                    <p class="text-muted mb-4">Заполните форму для создания новой записи</p>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-semibold text-secondary">Название игры</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Введите название" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm flex-grow-1">
                                <i class="bi bi-check-circle me-2"></i>Сохранить
                            </button>
                            <a asp-action="List" class="btn btn-outline-secondary btn-lg">
                                Отмена
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
