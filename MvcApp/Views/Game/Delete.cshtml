@model GameDisplayDeleteResponse
@{
    ViewData["Title"] = "Удалить игру";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-4 border-start border-danger border-4">
                <div class="card-body">
                    <h2 class="fw-bold text-danger mb-1">Удалить игру?</h2>
                    <p class="text-muted mb-4">Вы уверены, что хотите безвозвратно удалить эту запись?</p>

                    <div class="bg-light p-3 rounded mb-4">
                        <div class="text-muted small mb-1">ID: @Model.Id</div>
                        <h4 class="fw-bold text-dark mb-0">@Model.Name</h4>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger btn-lg shadow-sm flex-grow-1">
                                <i class="bi bi-trash me-2"></i>Да, удалить
                            </button>
                            <a asp-action="List" class="btn btn-outline-secondary btn-lg">
                                Отмена
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
