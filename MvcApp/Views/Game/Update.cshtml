@model GameDisplayUpdateResponse 
@{
    ViewData["Title"] = "Редактировать игру";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-4">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-1">
                        <h2 class="fw-bold text-primary mb-0">Редактировать</h2>
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-3">ID: @Model.Id</span>
                    </div>
                    <p class="text-muted mb-4">Внесите изменения в данные игры</p>

                    <form asp-action="Update" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-semibold text-secondary">Название игры</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Введите название" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm flex-grow-1">
                                <i class="bi bi-save me-2"></i>Сохранить изменения
                            </button>
                            <a asp-action="List" class="btn btn-outline-secondary btn-lg">
                                Отмена
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
