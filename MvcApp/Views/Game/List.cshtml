@model GameGetAllResponse

@{
    ViewData["Title"] = "Список игр";
}

<div class="container mt-5">
    <!-- Шапка страницы -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-primary mb-1">Каталог игр</h1>
            <p class="text-muted">Управляйте доступными играми в вашей системе</p>
        </div>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Добавить игру
        </a>
    </div>

    <!-- Проверка на пустоту -->
    @if (Model?.Games == null || !Model.Games.Any())
    {
        <div class="alert alert-info shadow-sm text-center py-5" role="alert">
            <h4 class="alert-heading fw-bold">Игры не найдены</h4>
            <p class="mb-0 text-muted">В базе данных пока нет ни одной записи. Нажмите кнопку выше, чтобы добавить первую игру.</p>
        </div>
    }
    else
    {
        <!-- Сетка (Карточки) -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var game in Model.Games)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 hover-shadow transition-all">
                        <div class="card-body d-flex flex-column justify-content-between p-4">
                            <div>
                                <div class="d-flex align-items-center mb-3">
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle me-2">
                                        ID: @game.Id
                                    </span>
                                </div>
                                <h5 class="card-title fw-bold text-dark mb-3">@game.Name</h5>
                            </div>

                            <!-- Кнопки действий -->
                            <div class="d-flex gap-2 mt-4 pt-3 border-top border-light">
                                <!-- Форма для отправки POST-запроса в метод Update -->
                                <form asp-action="Update" method="post" class="flex-grow-1">
                                    <input type="hidden" name="Id" value="@game.Id" />
                                    <input type="hidden" name="Name" value="@game.Name" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                        Изменить
                                    </button>
                                </form>

                                <a asp-action="Details" asp-route-id="@game.Id" class="btn btn-outline-primary btn-sm flex-grow-1 d-flex align-items-center justify-content-center">
                                    Детали
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Небольшие стили для красивого эффекта наведения (можно добавить в ваш site.css) -->
<style>
    .transition-all {
        transition: all 0.25s ease-in-out;
    }

    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.12) !important;
    }
</style>
